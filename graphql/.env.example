# Copy this file to graphql/.env and fill in your local values.
# Variable names match mojo/main/data/.env — you can copy them directly from there.

# Your local PostgreSQL credentials
DB_USER=        # your macOS username (same as `whoami`)
DB_PASSWORD=    # leave blank if your local postgres has no password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coursemojo

# Port the PostGraphile server listens on.
# The Vite dev server proxies /graphql here, so you rarely need to change this.
POSTGRAPHILE_PORT=5001
